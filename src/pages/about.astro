  },
  {
    year: "Jan 2026 – Present",
    title: "Teaching Assistant — Startup Software Project",
    subtitle: "Universitas Indonesia",
    description: "Guiding students through building real startup products — from ideation to shipping.",
    tags: ["TA: Startup Software Project"],
  },
  {
    year: "Sep 2025",
    title: "Young Leaders for Indonesia — Wave 17",
    subtitle: "YLI Foundation",
    description: "Selected as a Wave 17 Awardee for the Young Leaders for Indonesia program.",
    tags: ["Leadership", "Fellowship"],
    highlight: true,
  },
  {
    year: "2025 – Present",
    title: "Co Principal Researcher — Ragamaya VR",
