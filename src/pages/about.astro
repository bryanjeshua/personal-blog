    title: "Fasilkom UI — Computer Science",
    subtitle: "Universitas Indonesia",
    description: "Started undergrad in Computer Science. Joined Gladiatos robotics (AI Division) and EDUCARE as Fundraising Officer — raising funds from 4 main sponsors.",
    highlight: true,
  },
  {
    year: "2024",
    title: "Teaching Assistant — Discrete Mathematics 2",
    subtitle: "Universitas Indonesia",
    description: "100% peer approval rating. Provided one-on-one and group tutoring, evaluated submissions with constructive feedback. 87.5% students agreed the TA explains complicated concepts in an understandable way.",
    tags: ["TA: Discrete Math 2"],
  },
  {
