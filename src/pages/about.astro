  },
  {
    year: "2019 – 2022",
    title: "SMA Sang Timur",
    subtitle: "Valedictorian",
    description: "Student Body Leader. Best Civic Essay awardee. Member of the Astronomy Science Club. Built the foundation for leadership and curiosity.",
    tags: ["Valedictorian", "Student Body Leader", "Astronomy Club"],
    highlight: true,
  },
  {
    year: "2020 – 2022",
    title: "Social Media Officer",
    subtitle: "PT. Maxicount Indonesia · Haerde · Limans Consulting",
    description: "Created 620+ pieces of content — season greetings, microblogs, quotes — handling ideation, design, and copywriting for business development and HRIS startups.",
    tags: ["Content Creation", "Copywriting", "Design"],
  },
  {
