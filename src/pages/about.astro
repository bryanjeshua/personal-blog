<Layout title="About — Learn, Build, Tell" description="Learn more about Bryan Jeshua.">
  <!-- Gallery strip at the top -->
  <Gallery strip={true} />

  <section class="bg-surface-warm border-b border-border">
    <div class="max-w-6xl mx-auto px-5 py-16">
      <span class="text-xs font-bold uppercase tracking-widest text-primary-dark">Who I Am</span>
      <h1 class="font-display text-5xl md:text-6xl font-bold text-ink mt-2 tracking-tight">About</h1>
      <svg class="w-20 h-4 mt-6" viewBox="0 0 80 16" fill="none">
        <path d="M3 8 Q10 15 18 7 Q26 0 34 9 Q40 14 48 6 Q56 0 64 10 Q70 15 77 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" class="text-primary"/>
      </svg>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-16 px-5">
    <div class="max-w-3xl mx-auto prose-editorial">
      <h1>About Me</h1>
      <p>I'm Bryan Jeshua — an undergraduate Computer Science student at <strong>Universitas Indonesia</strong> (Fasilkom UI) with a deep passion for product management and building AI-powered solutions.</p>

      <h2>What I'm Doing Now</h2>
      <p><strong>Kapellmeister at Klaussa</strong> — I lead an AI legal-tech startup that serves as an AI co-pilot for lawyers and in-house legal teams. We've received Rp300 million in funding from UI Incubate, and are supported by <strong>Google for AI Startups</strong> and the <strong>NVIDIA Inception</strong> program.</p>
      <p><strong>Project Lead at Kalana Consulting</strong> — Leading consulting projects remotely.</p>
      <p><strong>Young Leaders for Indonesia</strong> — Wave 17 Awardee at YLI Foundation.</p>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-16 px-5 bg-surface-warm border-y border-border">
    <div class="max-w-3xl mx-auto">
      <span class="text-xs font-bold uppercase tracking-widest text-primary-dark">My Background</span>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-ink mt-2 tracking-tight mb-2">The Journey</h2>
      <svg class="w-16 h-4 mb-10" viewBox="0 0 64 16" fill="none">
        <path d="M2 9 Q9 2 16 10 Q23 16 30 6 Q37 0 44 10 Q51 15 58 7 L62 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" class="text-primary"/>
      </svg>

      <Timeline items={timeline} />
    </div>
  </section>

  <!-- Skills -->
  <section class="py-16 px-5">
    <div class="max-w-3xl mx-auto prose-editorial">
      <h2>Skills & Tools</h2>
      <ul>
        <li><strong>Product:</strong> Jira, Confluence, Amplitude, Postman, Notion, Figma</li>
        <li><strong>Languages:</strong> Python, JavaScript, Java, Dart</li>
        <li><strong>Frameworks:</strong> Flutter, Django, Bootstrap</li>
        <li><strong>ML/Data:</strong> PyTorch, Scikit-Learn, NumPy, Pandas, OpenCV</li>
        <li><strong>Infrastructure:</strong> Google Cloud, Docker, PostgreSQL, BigQuery</li>
      </ul>

      <h2>Let's Connect</h2>
      <p>I'm always open to conversations about product management, AI, startups, or anything you're building.</p>
      <ul>
        <li><strong>LinkedIn:</strong> <a href="https://www.linkedin.com/in/bryanjeshua/">bryanjeshua</a></li>
        <li><strong>GitHub:</strong> <a href="https://github.com/bryanjeshua">bryanjeshua</a></li>
        <li><strong>Email:</strong> bryanjmt04@gmail.com</li>
      </ul>
    </div>
  </section>
</Layout>
