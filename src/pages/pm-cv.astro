---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="PM CV — Bryan Jeshua" description="Product Management portfolio and CV for Bryan Jeshua — tiket.com, Klaussa, Superbank, Universitas Indonesia.">

  <!-- Print styles -->
  <style>
    @media print {
      .no-print { display: none !important; }
      .print-break { page-break-before: always; }
      body { background: white !important; color: black !important; }
      .md\:ml-16 { margin-left: 0 !important; }
    }
  </style>

  <!-- Top bar -->
  <section class="bg-surface-warm border-b border-border no-print">
    <div class="max-w-5xl mx-auto px-5 py-4 flex items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <a href={`${base}about`} class="text-xs font-semibold uppercase tracking-widest text-ink/40 hover:text-primary-dark transition-colors flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          Full profile
        </a>
        <span class="text-ink/20">/</span>
        <span class="text-xs font-bold uppercase tracking-widest text-primary-dark">PM CV</span>
      </div>
      <button
        onclick="window.print()"
        class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-ink/60 hover:text-primary-dark border border-border hover:border-primary-dark rounded px-3 py-1.5 transition-colors"
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
        </svg>
        Print / PDF
      </button>
    </div>
  </section>

  <!-- Header -->
  <section class="py-12 px-5 border-b border-border">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <div class="text-xs font-bold uppercase tracking-widest text-primary-dark mb-2">Product Manager · Builder · CS Undergrad</div>
          <h1 class="font-display text-5xl md:text-6xl font-bold text-ink tracking-tight leading-none">Bryan Jeshua</h1>
          <svg class="w-24 h-4 mt-4" viewBox="0 0 96 16" fill="none">
            <path d="M2 9 Q12 2 22 10 Q32 16 42 6 Q52 0 62 10 Q72 15 82 7 L94 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" class="text-primary"/>
          </svg>
          <p class="mt-5 text-base text-ink/70 max-w-xl leading-relaxed">
            PM intern at <strong class="text-ink">tiket.com</strong> (pricing × ML × behavioral economics).
            Founder of <strong class="text-ink">Klaussa</strong> — AI legal-tech backed by Google, NVIDIA &amp; UI Incubate.
            CS @ <strong class="text-ink">Universitas Indonesia</strong>, GPA 3.89.
            YLI Wave 17 Awardee. 16+ competition wins.
          </p>
        </div>
        <div class="flex flex-col gap-2 md:text-right shrink-0">
          <a href="mailto:bryanjmt04@gmail.com" class="text-sm text-ink/60 hover:text-primary-dark transition-colors flex md:justify-end items-center gap-2">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            bryanjmt04@gmail.com
          </a>
          <a href="https://www.linkedin.com/in/bryanjeshua/" target="_blank" rel="noopener noreferrer" class="text-sm text-ink/60 hover:text-primary-dark transition-colors flex md:justify-end items-center gap-2">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            linkedin.com/in/bryanjeshua
          </a>
          <a href="https://github.com/bryanjeshua" target="_blank" rel="noopener noreferrer" class="text-sm text-ink/60 hover:text-primary-dark transition-colors flex md:justify-end items-center gap-2">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
            github.com/bryanjeshua
          </a>
          <span class="text-sm text-ink/40 flex md:justify-end items-center gap-2 mt-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Jakarta, Indonesia
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Impact Numbers -->
  <section class="border-b border-border bg-surface-warm">
    <div class="max-w-5xl mx-auto px-5 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-border">
        {[
          { stat: "Rp1B+", label: "Total grants secured", sub: "Klaussa + Ragamaya + mentored teams" },
          { stat: "Rp850M+", label: "Sponsorship secured", sub: "Datathon 2024 as Event PIC" },
          { stat: "162%", label: "Participation growth", sub: "315+ teams, largest student datathon" },
          { stat: "16+", label: "Competition wins", sub: "13 personal · 3 team placements" },
        ].map(({ stat, label, sub }) => (
          <div class="bg-surface px-6 py-5">
            <div class="font-display text-3xl md:text-4xl font-bold text-primary-dark leading-none">{stat}</div>
            <div class="text-sm font-semibold text-ink mt-2 leading-snug">{label}</div>
            <div class="text-xs text-ink/40 mt-1 leading-snug">{sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Main content -->
  <div class="max-w-5xl mx-auto px-5 py-12">
    <div class="grid md:grid-cols-3 gap-12">

      <!-- Left col: sidebar -->
      <div class="md:col-span-1 space-y-10">

        <!-- Education -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest text-primary-dark mb-4">Education</div>
          <div class="space-y-5">
            <div>
              <div class="text-sm font-bold text-ink">Universitas Indonesia</div>
              <div class="text-xs text-ink/60 mt-0.5">B.Sc. Computer Science · Fasilkom UI</div>
              <div class="text-xs text-ink/40 mt-0.5">Sep 2022 – 2026</div>
              <div class="mt-2 inline-flex items-center text-xs font-semibold text-primary-dark bg-primary-dark/8 px-2 py-0.5 rounded-full">GPA 3.89 / 4.00</div>
            </div>
            <div>
              <div class="text-sm font-bold text-ink">Nanyang Technological University</div>
              <div class="text-xs text-ink/60 mt-0.5">INSPIRASI-NTU Summer Program 2025</div>
              <div class="text-xs text-ink/40 mt-0.5">Sustainability · Smart City · Circular Economy</div>
              <div class="mt-2 inline-flex items-center text-xs font-semibold text-primary-dark bg-primary-dark/8 px-2 py-0.5 rounded-full">LPDP Scholar · SGD 5,000</div>
            </div>
          </div>
        </div>

        <!-- Skills -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest text-primary-dark mb-4">Skills & Tools</div>
          <div class="space-y-3">
            {[
              { label: "Product", items: ["Jira", "Confluence", "Amplitude", "Figma", "Postman", "Notion"] },
              { label: "Technical", items: ["Python", "JavaScript", "Java", "Dart"] },
              { label: "ML / Data", items: ["PyTorch", "Scikit-Learn", "NumPy", "Pandas", "BigQuery"] },
              { label: "Infra", items: ["Google Cloud", "Docker", "PostgreSQL"] },
            ].map(({ label, items }) => (
              <div>
                <div class="text-[10px] font-bold uppercase tracking-widest text-ink/30 mb-1.5">{label}</div>
                <div class="flex flex-wrap gap-1.5">
                  {items.map(item => (
                    <span class="text-xs px-2 py-0.5 rounded border border-border text-ink/60">{item}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Recognitions -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest text-primary-dark mb-4">Selected Wins</div>
          <div class="space-y-2.5">
            {[
              { scope: "INTL", title: "Top 20 · Microsoft Elevate AI Impact Challenge", year: "2026" },
              { scope: "NATL", title: "Top 5 · AI Incubation for Public Sector — British Embassy × UK-Indonesia Tech Hub", year: "2026" },
              { scope: "NATL", title: "Gold Medal · GEMASTIK 2024 Software Development", year: "2024" },
              { scope: "INTL", title: "Finalist Top 10 · StudentxCEOs International Business Case", year: "2024" },
              { scope: "INTL", title: "Finalist Top 6 · International Ganesha Business Case", year: "2024" },
              { scope: "NATL", title: "1st Runner Up · ShARE UI Business Plan", year: "2024" },
              { scope: "NATL", title: "1st Winner · Management Exposed, FEB UI", year: "2023" },
              { scope: "NATL", title: "1st Runner Up · Tanoto Future Leader Startup & Pitching", year: "2023" },
            ].map(({ scope, title, year }) => (
              <div class="flex items-start gap-2">
                <span class={`text-[9px] font-bold px-1 py-0.5 rounded shrink-0 mt-0.5 ${scope === "INTL" ? "bg-primary-dark text-white" : "border border-primary-dark text-primary-dark"}`}>{scope}</span>
                <span class="text-xs text-ink/60 leading-snug flex-1">{title}</span>
                <span class="text-[10px] text-ink/30 shrink-0 pt-0.5">{year}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Speaking (condensed) -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest text-primary-dark mb-4">Speaking</div>
          <div class="space-y-2">
            {[
              { title: "From Academic Projects to Real World Impact", context: "with Felix Nugroho (CTO Ismaya) & Budhi Riyanta (CMO Medi-Call)", date: "Jun 2026", url: "https://www.instagram.com/p/DZbUZc6E-am/?img_index=1" },
              { title: "Navigating the AI Era", context: "Universitas YARSI · 106 participants", date: "May 2026", url: "https://www.yarsi.ac.id/navigating-the-ai-era-literacy-industry-perspective-and-implementation" },
              { title: "Klaussa Spinoff — Dies Natalis Fasilkom UI", context: "UI Center for Legal Informatics launch", date: "Nov 2025", url: "https://megapolitan.antaranews.com/berita/466629/fasilkom-ui-luncurkan-lexin-perkuat-riset-ai-di-bidang-hukum" },
            ].map(({ title, context, date, url }) => (
              <div class="py-2 border-b border-border last:border-0">
                <a href={url} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-ink hover:text-primary-dark transition-colors underline underline-offset-2 decoration-border hover:decoration-primary-dark leading-snug">{title}</a>
                <div class="text-[10px] text-ink/40 mt-0.5">{context} · {date}</div>
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- Right col: experience -->
      <div class="md:col-span-2 space-y-10">

        <!-- PM Narrative -->
        <div class="p-5 border border-primary-dark/20 bg-primary-dark/4 rounded-sm">
          <div class="text-xs font-bold uppercase tracking-widest text-primary-dark mb-3">Why PM</div>
          <p class="text-sm text-ink/80 leading-relaxed">
            I gravitate toward PM because it sits at the intersection of user behavior, data, and business systems — the exact territory I've explored at tiket.com (pricing × behavioral economics × ML), inside Klaussa (0→1 AI product), and across 10+ institutional partnerships at RISTEK. I'm most energized when a product decision has measurable downstream impact, and I have the technical depth to collaborate fluently with engineers while staying focused on outcomes.
          </p>
        </div>

        <!-- Experience -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest text-primary-dark mb-6">Experience</div>
          <div class="space-y-8">

            {/* Klaussa */}
            <div class="flex gap-5">
              <div class="w-1 rounded-full bg-primary-dark shrink-0 self-stretch"></div>
              <div class="flex-1 pb-2">
                <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                  <h3 class="text-base font-bold text-ink">Klaussa Indonesia</h3>
                  <span class="text-xs text-ink/40 shrink-0">Jul 2025 – Present</span>
                </div>
                <div class="text-sm font-medium text-ink/60 mt-0.5">Kapellmeister (Founder / CEO) · AI Legal-Tech Startup</div>
                <ul class="mt-3 space-y-1.5">
                  {[
                    "Building an AI co-pilot for lawyers — turning weeks of contract analysis into 15 minutes",
                    "Secured Rp300M preseed from UI Incubate; accepted into Google for AI Startups and NVIDIA Inception Program",
                    "Defined product roadmap, led go-to-market strategy, and managed end-to-end engineering delivery",
                    "Presented Klaussa spinoff at Dies Natalis Fasilkom UI alongside the UI Center for Legal Informatics launch",
                  ].map(bullet => (
                    <li class="flex items-start gap-2 text-sm text-ink/70 leading-relaxed">
                      <span class="mt-2 w-1 h-1 rounded-full bg-primary-dark shrink-0"></span>
                      {bullet}
                    </li>
                  ))}
                </ul>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {["Product Strategy", "0→1", "AI/ML", "Google for Startups", "NVIDIA Inception"].map(t => (
                    <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-primary-dark/8 text-primary-dark">{t}</span>
                  ))}
                </div>
              </div>
            </div>

            {/* Superbank PMO */}
            <div class="flex gap-5">
              <div class="w-1 rounded-full bg-primary-dark shrink-0 self-stretch"></div>
              <div class="flex-1 pb-2">
                <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                  <h3 class="text-base font-bold text-ink">Superbank</h3>
                  <span class="text-xs text-ink/40 shrink-0">Jan – Mar 2026</span>
                </div>
                <div class="text-sm font-medium text-ink/60 mt-0.5">Project Management Office · Seasonal</div>
                <ul class="mt-3 space-y-1.5">
                  {[
                    "Conducted as part of the Breakthrough Leadership Project under Young Leaders for Indonesia by McKinsey & Company",
                    "Operated within Superbank's PMO function as part of a cohort-based leadership initiative",
                  ].map(bullet => (
                    <li class="flex items-start gap-2 text-sm text-ink/70 leading-relaxed">
                      <span class="mt-2 w-1 h-1 rounded-full bg-primary-dark shrink-0"></span>
                      {bullet}
                    </li>
                  ))}
                </ul>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {["PMO", "McKinsey × YLI", "Fintech"].map(t => (
                    <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-primary-dark/8 text-primary-dark">{t}</span>
                  ))}
                </div>
              </div>
            </div>

            {/* tiket.com */}
            <div class="flex gap-5">
              <div class="w-1 rounded-full bg-primary-dark shrink-0 self-stretch"></div>
              <div class="flex-1 pb-2">
                <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                  <h3 class="text-base font-bold text-ink">tiket.com</h3>
                  <span class="text-xs text-ink/40 shrink-0">Mar – Sep 2025</span>
                </div>
                <div class="text-sm font-medium text-ink/60 mt-0.5">Product Management — Pricing · Internship</div>
                <ul class="mt-3 space-y-1.5">
                  {[
                    "Worked on dynamic pricing strategy at one of Indonesia's largest OTA platforms",
                    "Applied machine learning, data science, and behavioral economics to pricing decisions at scale",
                    "Bridged data science output with product requirements — translating model results into user-facing features",
                    "Gained hands-on experience with Jira, Amplitude, and cross-functional PM workflows",
                  ].map(bullet => (
                    <li class="flex items-start gap-2 text-sm text-ink/70 leading-relaxed">
                      <span class="mt-2 w-1 h-1 rounded-full bg-primary-dark shrink-0"></span>
                      {bullet}
                    </li>
                  ))}
                </ul>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {["Pricing Strategy", "Behavioral Economics", "ML × Product", "Jira", "Amplitude"].map(t => (
                    <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-primary-dark/8 text-primary-dark">{t}</span>
                  ))}
                </div>
              </div>
            </div>

            {/* Kalana */}
            <div class="flex gap-5">
              <div class="w-1 rounded-full bg-primary shrink-0 self-stretch"></div>
              <div class="flex-1 pb-2">
                <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                  <h3 class="text-base font-bold text-ink">Kalana Consulting</h3>
                  <span class="text-xs text-ink/40 shrink-0">Jan 2026 – Present</span>
                </div>
                <div class="text-sm font-medium text-ink/60 mt-0.5">Project Lead · Full-time Remote</div>
                <ul class="mt-3 space-y-1.5">
                  {[
                    "Leading client consulting projects end-to-end in a fully remote capacity",
                    "Top 5 in AI Incubation for Public Sector — British Embassy Jakarta × UK-Indonesia Tech Hub",
                  ].map(bullet => (
                    <li class="flex items-start gap-2 text-sm text-ink/70 leading-relaxed">
                      <span class="mt-2 w-1 h-1 rounded-full bg-primary shrink-0"></span>
                      {bullet}
                    </li>
                  ))}
                </ul>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {["Consulting", "Project Management", "AI Strategy"].map(t => (
                    <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-primary/10 text-primary-dark">{t}</span>
                  ))}
                </div>
              </div>
            </div>

            {/* RISTEK */}
            <div class="flex gap-5">
              <div class="w-1 rounded-full bg-border shrink-0 self-stretch"></div>
              <div class="flex-1 pb-2">
                <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                  <h3 class="text-base font-bold text-ink">RISTEK Fasilkom UI</h3>
                  <span class="text-xs text-ink/40 shrink-0">2024</span>
                </div>
                <div class="text-sm font-medium text-ink/60 mt-0.5">Vice Director of Business Growth · PIC Datathon 2024</div>
                <ul class="mt-3 space-y-1.5">
                  {[
                    "Established 10+ institutional partnerships and new revenue streams, acquired and onboarded by Faculty boards",
                    "As PIC of Datathon 2024: secured Rp850M+ in sponsorship, grew participation 162% to 315+ teams",
                    "Transformed Datathon into the largest student-led data competition in Indonesia",
                  ].map(bullet => (
                    <li class="flex items-start gap-2 text-sm text-ink/70 leading-relaxed">
                      <span class="mt-2 w-1 h-1 rounded-full bg-border shrink-0"></span>
                      {bullet}
                    </li>
                  ))}
                </ul>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {["Partnerships", "Business Development", "Event Strategy", "Rp850M+ Secured"].map(t => (
                    <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full border border-border text-ink/50">{t}</span>
                  ))}
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- Research -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest text-primary-dark mb-4">Research</div>
          <div class="flex gap-5">
            <div class="w-1 rounded-full bg-border shrink-0 self-stretch"></div>
            <div>
              <div class="text-base font-bold text-ink">Ragamaya VR — Co Principal Researcher</div>
              <div class="text-sm font-medium text-ink/60 mt-0.5">Universitas Indonesia × SMPK St. Ignatius Loyola, Labuan Bajo · 2025 – Present</div>
              <ul class="mt-3 space-y-1.5">
                {[
                  "Pitched and secured Rp150,000,000 in research funding",
                  "Leading research direction for a VR experience preserving NTT folk stories — built with Unity & Blender",
                  "Participatory qualitative methodology alongside local community members in Labuan Bajo",
                  "Led institutional talks with Kepala Dinas Pemuda, Pendidikan, dan Olahraga Manggarai Barat",
                  "Target: advancing Technology Readiness Level from TKT 4 to TKT 5",
                ].map(bullet => (
                  <li class="flex items-start gap-2 text-sm text-ink/70 leading-relaxed">
                    <span class="mt-2 w-1 h-1 rounded-full bg-border shrink-0"></span>
                    {bullet}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <!-- Mentoring -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest text-primary-dark mb-4">Mentoring Impact</div>
          <div class="grid sm:grid-cols-2 gap-3">
            {[
              { team: "Pinkmatcha Studio", result: "Incubated · Preseed Rp300,000,000", year: "2026" },
              { team: "Nura", result: "Hultprize · Microsoft AI Demoday · Best Software Project Fasilkom", year: "2026" },
              { team: "3 teams · GEMASTIK 2025", result: "All 3 teams reached the final round (Software Dev + IoT)", year: "2025" },
              { team: "Kretacat Express", result: "1st Place — ITB Game Competition", year: "2026" },
            ].map(({ team, result, year }) => (
              <div class="p-3.5 border border-border rounded-sm">
                <div class="text-xs font-bold text-ink">{team}</div>
                <div class="text-xs text-ink/50 mt-1 leading-snug">{result}</div>
                <div class="text-[10px] text-ink/30 mt-1">{year}</div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Footer CTA -->
