---
interface TimelineItem {
  year: string;
  title: string;
  subtitle?: string;
  description?: string;
  tags?: string[];
  highlight?: boolean;
}

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props;
---

<div class="relative">
  <!-- Vertical line -->
  <div class="absolute left-[9px] md:left-[11px] top-3 bottom-3 w-[2px] bg-border"></div>

  <div class="space-y-8">
    {items.map((item, i) => (
      <div class="relative flex gap-6 group">
        <!-- Dot -->
        <div class="relative z-10 flex-shrink-0 mt-1.5">
          <div class:list={[
            "w-5 h-5 md:w-6 md:h-6 rounded-full border-[2.5px] transition-colors duration-300",
            item.highlight
              ? "bg-primary border-primary"
              : "bg-surface border-border group-hover:border-primary"
          ]}></div>
        </div>

        <!-- Content -->
        <div class="pb-2 flex-1">
          <span class="text-xs font-bold uppercase tracking-widest text-primary-dark">{item.year}</span>
          <h3 class="font-display text-lg md:text-xl font-bold text-ink mt-1 leading-tight">{item.title}</h3>
          {item.subtitle && (
            <p class="text-sm text-ink-muted mt-1 font-medium">{item.subtitle}</p>
          )}
          {item.description && (
            <p class="text-ink-light text-[0.95rem] mt-2 leading-relaxed">{item.description}</p>
          )}
          {item.tags && item.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-3">
              {item.tags.map((tag) => (
                <span class="text-[10px] font-bold uppercase tracking-widest text-primary-dark bg-primary/15 px-2 py-0.5">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
</div>
