---
interface Props {
  title: string;
  subtitle: string;
  ctaText: string;
  ctaLink: string;
}

const { title, subtitle, ctaText, ctaLink } = Astro.props;
---

<section class="relative bg-surface-warm overflow-hidden">
  <!-- Decorative elements -->
  <div class="absolute top-0 right-0 w-72 h-72 bg-primary/10 rounded-full -translate-y-1/2 translate-x-1/3"></div>
  <div class="absolute bottom-0 left-0 w-48 h-48 bg-primary/8 rounded-full translate-y-1/3 -translate-x-1/4"></div>

  <div class="max-w-6xl mx-auto px-5 py-24 md:py-32 relative">
    <div class="max-w-3xl">
      <div class="animate-fade-up">
        <span class="inline-block bg-primary text-surface-dark text-xs font-bold uppercase tracking-widest px-3 py-1.5 mb-6">
          Welcome
        </span>
      </div>

      <h1 class="font-display text-5xl md:text-7xl font-bold tracking-tight text-ink leading-[1.05] animate-fade-up animate-delay-1">
        {title}
      </h1>

      <p class="mt-6 text-xl md:text-2xl text-ink-light leading-relaxed font-light max-w-2xl animate-fade-up animate-delay-2">
        {subtitle}
      </p>

      <div class="mt-10 flex items-center gap-6 animate-fade-up animate-delay-3">
        <a
          href={ctaLink}
          class="inline-flex items-center gap-2 bg-ink text-cta-text font-semibold px-7 py-3.5 text-sm uppercase tracking-wider hover:bg-primary hover:text-ink transition-all duration-300"
        >
          {ctaText}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <span class="hidden md:block w-12 h-0.5 bg-primary"></span>
      </div>
    </div>
  </div>

  <!-- Bottom border accent -->
  <div class="h-0.5 bg-gradient-to-r from-primary via-primary/50 to-transparent"></div>
</section>
