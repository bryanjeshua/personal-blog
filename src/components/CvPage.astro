---
import Layout from '../layouts/Layout.astro';

const variants = {
  pm: {
    label: 'PM CV',
    title: 'PM CV — Bryan Jeshua',
    description: 'Product Management portfolio and CV for Bryan Jeshua — tiket.com, Klaussa, Superbank, Universitas Indonesia.',
    eyebrow: 'Product Manager · Builder · CS Undergrad',
    heroSummary: "I build products that work, people love, and change how things get done. From shipping ML-driven pricing at tiket.com that lifted Rp250M/month in revenue, to spinning off my professor's research lab (Lexin) into Klaussa, an AI legal-tech platform used by 200+ lawyers and backed by Google, NVIDIA & UI Incubate, I turn vision into products that are economically real and built to last. Was a CS student at Universitas Indonesia. YLI Wave 17. 16+ wins.",
    narrativeTitle: 'Why PM',
    narrative: "I gravitate toward PM because it sits at the intersection of user behavior, data, and business systems — the exact territory I've explored at tiket.com (pricing × behavioral economics × ML), inside Klaussa (0→1 AI product), and across 10+ institutional partnerships at RISTEK. I'm most energized when a product decision has measurable downstream impact, and I have the technical depth to collaborate fluently with engineers while staying focused on outcomes.",
    downloadHref: 'bryan-jeshua-pm-cv.pdf',
    downloadFilename: 'Bryan-Jeshua-PM-CV.pdf',
    location: 'Jakarta, Indonesia',
    ragamayaRole: 'Co Principal Researcher',
    printTagline: 'Product Manager · Builder · CS Graduate, Universitas Indonesia',
    printSummary: 'I build products that work, people love, and change how things get done. From shipping ML-driven pricing at tiket.com that lifted Rp250M/month in revenue, to spinning off a university research lab into Klaussa, an AI legal-tech platform used by 200+ lawyers and backed by Google, NVIDIA, and UI Incubate, I turn vision into products that are economically real and built to last. YLI Wave 17 Awardee. 16+ competition wins nationally and internationally.',
  },
  po: {
    label: 'PO CV',
    title: 'Product Owner CV — Bryan Jeshua',
    description: 'Product Owner and ICT Business Analyst CV for Bryan Jeshua, targeting Australia roles across AI, pricing, B2B SaaS, legal-tech, OTA, and public-sector digital products.',
    eyebrow: 'Product Owner · ICT Business Analyst · Australia Target',
    heroSummary: 'Product Owner / ICT Business Analyst with experience across AI, pricing, B2B SaaS, legal-tech, OTA, and public-sector digital products. Built and scaled AI-native products from 0 to 1 at Klaussa, growing the platform to 250+ users and partners, and contributed to ML-driven pricing initiatives at tiket.com, one of Indonesia’s largest OTAs serving millions of users. Skilled in translating business needs into structured requirements, workflows, user stories, and delivered software solutions with measurable adoption, revenue, and stakeholder impact.',
    narrativeTitle: 'Why Product Owner / ICT BA',
    narrative: 'I work well where business ambiguity needs to become clear delivery scope: stakeholder needs, process flows, user stories, acceptance criteria, and shipped software. My experience spans AI legal-tech, pricing systems, public-sector AI pilots, OTA products, and B2B SaaS, with enough technical depth to work closely with engineers while keeping user adoption, stakeholder alignment, and business outcomes visible.',
    downloadHref: 'bryan-jeshua-po-cv.pdf',
    downloadFilename: 'Bryan-Jeshua-PO-CV.pdf',
    location: 'Jakarta, Indonesia | Open to relocation to Australia and Asia',
    ragamayaRole: 'Product Owner Lead',
    printTagline: 'Product Owner / ICT Business Analyst · Australia Target · CS Graduate, Universitas Indonesia',
    printSummary: 'Product Owner / ICT Business Analyst with experience across AI, pricing, B2B SaaS, legal-tech, OTA, and public-sector digital products. Built and scaled AI-native products from 0 to 1 at Klaussa, growing the platform to 250+ users and partners, and contributed to ML-driven pricing initiatives at tiket.com, one of Indonesia’s largest OTAs serving millions of users. Skilled in translating business needs into structured requirements, workflows, user stories, and delivered software solutions with measurable adoption, revenue, and stakeholder impact.',
  },
  tpm: {
    label: 'TPM CV',
    title: 'Technical Product Manager CV — Bryan Jeshua',
    description: 'Technical Product Manager CV for Bryan Jeshua, targeting Australia roles across AI, pricing, B2B SaaS, legal-tech, OTA, and public-sector digital products.',
    eyebrow: 'Technical Product Manager · AI Products · Australia Target',
    heroSummary: 'Technical Product Manager with experience across AI, pricing, B2B SaaS, legal-tech, OTA, and public-sector digital products. Launched and grew AI-native products from 0 to 1 at Klaussa to 250+ users and institutional partners, and contributed to ML-driven pricing initiatives at tiket.com, one of Indonesia’s largest OTAs serving millions of users. Strong in translating ambiguous problems into product strategy, technical requirements, scalable systems, and measurable revenue, adoption, and delivery impact.',
    narrativeTitle: 'Why Technical Product Management',
    narrative: 'I sit comfortably between product strategy and technical execution: roadmaps, system requirements, API and data considerations, AI architecture tradeoffs, observability, and shipped outcomes. Across Klaussa, tiket.com, Kalana, and robotics work, I have translated ambiguous problems into technical plans, aligned engineers and stakeholders, and delivered products with measurable adoption, revenue, and operational impact.',
    downloadHref: 'bryan-jeshua-tpm-cv.pdf',
    downloadFilename: 'Bryan-Jeshua-TPM-CV.pdf',
    location: 'Jakarta, Indonesia | Open to relocation to Australia and Asia',
    ragamayaRole: 'Technical Product Manager Lead',
    printTagline: 'Technical Product Manager · AI Products · CS Graduate, Universitas Indonesia',
    printSummary: 'Technical Product Manager with experience across AI, pricing, B2B SaaS, legal-tech, OTA, and public-sector digital products. Launched and grew AI-native products from 0 to 1 at Klaussa to 250+ users and institutional partners, and contributed to ML-driven pricing initiatives at tiket.com, one of Indonesia’s largest OTAs serving millions of users. Strong in translating ambiguous problems into product strategy, technical requirements, scalable systems, and measurable revenue, adoption, and delivery impact.',
  },
};

type VariantKey = keyof typeof variants;

interface Props {
  variant?: VariantKey;
}

const { variant = 'pm' } = Astro.props;
const cv = variants[variant] ?? variants.pm;
const base = import.meta.env.BASE_URL;
const isPo = variant === 'po';
const klaussaBullets = isPo
  ? [
      "Led user discovery with lawyers, law students, and legal NGOs; turned findings into roadmap priorities, grew to 200+ users and corporate partners in 2 months, and simplified low-adoption features based on feedback",
      "Defined technical requirements with engineering for agentic AI workflows, document extraction, rate limiting, multi-tenant data handling, and cost observability; secured Rp300M preseed and joined Google for AI Startups plus NVIDIA Inception",
      "Built engineering from 0 to 1 by hiring a 7-person team, defining the stack, CI/CD culture, delivery rhythm, and cross-functional product execution",
    ]
  : [
      "Led user discovery with lawyers, law students, and legal NGOs; turned findings into roadmap priorities, grew to 200+ users and corporate partners in 2 months, and simplified low-adoption features based on feedback",
      "Architected an agentic AI system for contract review and legal research using LangChain and Gemini, with orchestrator/sub-agent flows, on-premise hosting, and LangFuse cost observability",
      "Built a legal document pipeline for 300,000+ decisions, contracts, and regulations using PDF parsing, OCR, and custom chunking, and designed rate-limited, multi-tenant infrastructure on Redis, GCP, and PostgreSQL",
      "Built engineering from 0 to 1 by hiring a 7-person team, defining the stack and CI/CD culture, and secured Rp300M preseed plus acceptance into Google for AI Startups and NVIDIA Inception",
    ];
const kalanaBullets = isPo
  ? [
      "Worked with public-sector and consulting stakeholders to define problem statements, product scope, business requirements, feasibility narratives, and delivery plans for government-facing AI pilots",
      "Advised a game studio on funding readiness by preparing venture capital and government-auditor presentations, aligning product roadmap with budget deployment, and strengthening regulatory and economic feasibility, contributing to Rp300M in funding",
      "Advised a game studio on product strategy by realigning roadmap priorities, refining market sizing, defining vertical-slice requirements, and sharpening narrative positioning, contributing to a game development competition win",
      "Facilitated connections with Garena, Xbox, Sony, and Tencent, plus media and community partners, distributors, and publicists",
    ]
  : [
      "Worked hand in hand with government officials and a larger consulting firm to deliver pilot solutions for the Ministry of Finance; Top 5 in AI Incubation for Public Sector — British Embassy Jakarta x UK-Indonesia Tech Hub",
      "Advised a game studio on funding readiness by preparing venture capital and government-auditor presentations, aligning product roadmap with budget deployment, and strengthening regulatory and economic feasibility, contributing to Rp300M in funding",
      "Advised a game studio on product strategy by realigning roadmap priorities, refining market sizing, defining vertical-slice requirements, and sharpening narrative positioning, contributing to a game development competition win",
      "Facilitated connections with Garena, Xbox, Sony, and Tencent, plus media and community partners, distributors, and publicists",
    ];
const tiketBullets = isPo
  ? [
      "Contributed to ML-driven pricing initiatives for insurance and train products at tiket.com, one of Indonesia's largest OTAs serving millions of users; wrote EDDs, defined feature specs, aligned data scientists on model selection, tracked success metrics, and delivered Rp250M/month revenue lift and 130++% internal vertical growth",
      "Led a deployed RL-inspired user segmentation system using purchase history, price sensitivity, and cross-product transactions to enable customized pricing per user",
      "Designed a behavioral economics nudge strategy with A/B testing, using urgency, social proof, anchoring, and loss-aversion cues to drive earlier purchase",
      "Defined a competitor price scraping strategy that improved OTA comparison data quality, increased coverage by 190% with a 10% budget increase, and expanded inventory coverage",
    ]
  : [
      "Led an ML-based pricing initiative for insurance and train products, wrote the EDD and feature specs, aligned data scientists on model selection, and delivered Rp250M/month revenue lift",
      "Led a deployed RL-inspired user segmentation system using purchase history, price sensitivity, and cross-product transactions to enable customized pricing per user",
      "Designed a behavioral economics nudge strategy with A/B testing, using urgency, social proof, anchoring, and loss-aversion cues to drive earlier purchase",
      "Defined a competitor price scraping strategy that improved OTA comparison data quality, increased coverage by 190% with a 10% budget increase, and expanded inventory coverage",
    ];
const selectedWins = isPo
  ? [
      { scope: "NATL", title: "Gold Medal · GEMASTIK 2024 Software Development", year: "2024" },
      { scope: "INTL", title: "Top 5% Worldwide · Startup Wheel", year: "2026" },
      { scope: "NATL", title: "Young Leaders for Indonesia — Wave 17 Awardee, McKinsey & YLI Foundation", year: "2025" },
      { scope: "NATL", title: "Top 5 · AI Incubation for Public Sector — British Embassy x UK-Indonesia Tech Hub", year: "2026" },
      { scope: "INTL", title: "Top 20 · Microsoft Elevate AI Impact Challenge", year: "2026" },
      { scope: "NATL", title: "1st Winner · Management Exposed, FEB UI", year: "2023" },
    ]
  : [
      { scope: "INTL", title: "Top 20 · Microsoft Elevate AI Impact Challenge", year: "2026" },
      { scope: "NATL", title: "Top 5 · AI Incubation for Public Sector — British Embassy x UK-Indonesia Tech Hub", year: "2026" },
      { scope: "NATL", title: "Gold Medal · GEMASTIK 2024 Software Development", year: "2024" },
      { scope: "INTL", title: "Finalist Top 10 · StudentxCEOs International Business Case", year: "2024" },
      { scope: "INTL", title: "Finalist Top 6 · International Ganesha Business Case", year: "2024" },
      { scope: "NATL", title: "1st Runner Up · ShARE UI Business Plan", year: "2024" },
      { scope: "NATL", title: "1st Winner · Management Exposed, FEB UI", year: "2023" },
      { scope: "NATL", title: "1st Runner Up · Tanoto Future Leader Startup & Pitching", year: "2023" },
    ];
const printSkills = isPo
  ? [
      { label: "Product Ownership / BA", value: "Requirements Gathering, User Stories, Acceptance Criteria, Workflow Mapping, Backlog Prioritisation, Roadmaps, Stakeholder Management, UAT, OKR, PRD, EDD" },
      { label: "Tools", value: "Jira, Confluence, Figma, Notion, Amplitude, Postman, BigQuery" },
      { label: "Technical", value: "API Requirements, Technical Discovery, System Design Understanding, SQL, Python, JavaScript, GCP, Docker, PostgreSQL, Redis" },
      { label: "AI / Data", value: "LangChain, LangFuse, Gemini, Prompt Engineering, ML Pricing, A/B Testing, User Segmentation" },
      { label: "Domain", value: "AI Products, Legal-Tech, Pricing Strategy, B2B SaaS, OTA, Public-Sector Digital Products, Game Industry" },
    ]
  : [
      { label: "Product", value: "Jira, Confluence, Amplitude, Figma, Postman, Notion, EDD, A/B Testing" },
      { label: "AI / Agentic", value: "LangChain, LangFuse, Gemini, Prompt Engineering, On-premise LLM" },
      { label: "ML / Data", value: "PyTorch, Scikit-Learn, Pandas, NumPy, BigQuery, RL Simulation" },
      { label: "Infra", value: "GCP, Docker, PostgreSQL, Redis, CI/CD" },
      { label: "Languages", value: "Python, JavaScript, Java, Dart, SQL" },
      { label: "Domain", value: "Pricing Strategy, Behavioral Economics, Legal-Tech, Game Industry, B2B SaaS" },
    ];
const screenSkillGroups = isPo
  ? [
      { label: "Product Ownership / BA", items: ["Requirements Gathering", "User Stories", "Acceptance Criteria", "Workflow Mapping", "Backlog Prioritisation", "Roadmaps", "Stakeholder Management", "UAT", "OKR", "PRD", "EDD"] },
      { label: "Tools", items: ["Jira", "Confluence", "Figma", "Notion", "Amplitude", "Postman", "BigQuery"] },
      { label: "Technical", items: ["API Requirements", "Technical Discovery", "System Design Understanding", "SQL", "Python", "JavaScript", "GCP", "Docker", "PostgreSQL", "Redis"] },
      { label: "AI / Data", items: ["LangChain", "LangFuse", "Gemini", "Prompt Engineering", "ML Pricing", "A/B Testing", "User Segmentation"] },
      { label: "Domain", items: ["AI Products", "Legal-Tech", "Pricing Strategy", "B2B SaaS", "OTA", "Public-Sector Digital Products", "Game Industry"] },
    ]
  : [
      { label: "Product", items: ["Jira", "Confluence", "Amplitude", "Figma", "Notion", "PRD", "EDD", "OKR", "Roadmap", "User Research", "A/B Testing"] },
      { label: "AI / Agentic", items: ["LangChain", "LangFuse", "Gemini", "Agentic Systems", "Prompt Engineering", "On-premise LLM"] },
      { label: "ML / Data", items: ["PyTorch", "Scikit-Learn", "Pandas", "NumPy", "BigQuery", "RL Simulation"] },
      { label: "Infra", items: ["GCP", "Docker", "PostgreSQL", "Redis", "CI/CD"] },
      { label: "Languages", items: ["Python", "JavaScript", "Java", "Dart", "SQL"] },
      { label: "Domain", items: ["Pricing Strategy", "Behavioral Economics", "Legal-Tech", "Game Industry", "B2B SaaS"] },
    ];
---

<Layout title={cv.title} description={cv.description}>

  <!-- Print styles -->
  <style>
    @media print {
      @page { margin: 0.55in 0.65in; size: A4; }

      /* Hide nav, footer, all web sections */
      nav, #sidebar, #mobile-nav, footer,
      .no-print { display: none !important; }

      /* Strip main margin added by Layout */
      main { margin: 0 !important; padding: 0 !important; }

      /* Hide all page sections, show only print CV */
      main > *:not(#print-cv) { display: none !important; }

      #print-cv {
        display: block !important;
        max-width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
      }

      /* Page break rules */
      #print-cv .cv-entry { page-break-inside: avoid; }
      #print-cv h2 { page-break-after: avoid; }
      #print-cv ul { page-break-inside: avoid; }
      * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    }

    #print-cv {
      display: none;
      font-family: 'Arial', 'Helvetica', sans-serif;
      font-size: 10.5pt;
      line-height: 1.4;
      color: #000;
      background: #fff;
      max-width: 780px;
      margin: 0 auto;
      padding: 36px 40px;
    }

    #print-cv h1 { font-size: 20pt; font-weight: 700; margin: 0 0 2px; letter-spacing: -0.3px; }
    #print-cv .cv-tagline { font-size: 10pt; color: #444; margin: 0 0 6px; }
    #print-cv .cv-contact { font-size: 9pt; color: #444; margin-bottom: 14px; }
    #print-cv .cv-contact a { color: #444; text-decoration: none; }
    #print-cv hr { border: none; border-top: 1.5px solid #000; margin: 10px 0 8px; }
    #print-cv h2 { font-size: 10pt; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin: 14px 0 6px; border-bottom: 0.5px solid #ccc; padding-bottom: 2px; }
    #print-cv .cv-entry { margin-bottom: 10px; }
    #print-cv .cv-entry-header { display: flex; justify-content: space-between; align-items: baseline; }
    #print-cv .cv-org { font-weight: 700; font-size: 10.5pt; }
    #print-cv .cv-org a { color: #000; text-decoration: none; }
    #print-cv .cv-date { font-size: 9pt; color: #555; white-space: nowrap; }
    #print-cv .cv-role { font-size: 9.5pt; color: #333; margin: 1px 0 4px; font-style: italic; }
    #print-cv ul { margin: 3px 0 0 0; padding-left: 14px; }
    #print-cv ul li { margin-bottom: 2px; font-size: 9.5pt; color: #111; }
    #print-cv .cv-skills-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 4px 16px; }
    #print-cv .cv-skill-row { font-size: 9pt; }
    #print-cv .cv-skill-label { font-weight: 700; }
    #print-cv .cv-wins { columns: 2; column-gap: 20px; }
    #print-cv .cv-win { font-size: 9pt; margin-bottom: 2px; break-inside: avoid; }
    #print-cv .cv-win-scope { font-weight: 700; margin-right: 4px; }

    @media print {
      #print-cv { display: block !important; }
    }
  </style>

  <!-- Top bar -->
  <section class="bg-surface-warm border-b border-border no-print">
    <div class="max-w-5xl mx-auto px-5 py-4 flex items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <a href={`${base}about`} class="text-xs font-semibold uppercase tracking-widest text-ink/40 hover:text-primary-dark transition-colors flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          Full profile
        </a>
        <span class="text-ink/20">/</span>
        <span class="text-xs font-bold uppercase tracking-widest text-primary-dark">{cv.label}</span>
      </div>
      <a
        href={`${base}${cv.downloadHref}`}
        download={cv.downloadFilename}
        class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-ink/60 hover:text-primary-dark border border-border hover:border-primary-dark rounded px-3 py-1.5 transition-colors"
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Download CV
      </a>
    </div>
  </section>

  <!-- Header -->
  <section class="py-12 px-5 border-b border-border">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <div class="text-xs font-bold uppercase tracking-widest text-primary-dark mb-2">{cv.eyebrow}</div>
          <h1 class="font-display text-5xl md:text-6xl font-bold text-ink tracking-tight leading-none">Bryan Jeshua</h1>
          <svg class="w-24 h-4 mt-4" viewBox="0 0 96 16" fill="none">
            <path d="M2 9 Q12 2 22 10 Q32 16 42 6 Q52 0 62 10 Q72 15 82 7 L94 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" class="text-primary"/>
          </svg>
          <p class="mt-5 text-base text-ink/70 max-w-xl leading-relaxed">
            {cv.heroSummary}
          </p>
        </div>
        <div class="flex flex-col gap-2 md:text-right shrink-0">
          <a href="mailto:bryanjmt04@gmail.com" class="text-sm text-ink/60 hover:text-primary-dark transition-colors flex md:justify-end items-center gap-2">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            bryanjmt04@gmail.com
          </a>
          <a href="https://www.linkedin.com/in/bryanjeshua/" target="_blank" rel="noopener noreferrer" class="text-sm text-ink/60 hover:text-primary-dark transition-colors flex md:justify-end items-center gap-2">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            linkedin.com/in/bryanjeshua
          </a>
          <a href="https://github.com/bryanjeshua" target="_blank" rel="noopener noreferrer" class="text-sm text-ink/60 hover:text-primary-dark transition-colors flex md:justify-end items-center gap-2">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
            github.com/bryanjeshua
          </a>
          <span class="text-sm text-ink/40 flex md:justify-end items-center gap-2 mt-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            {cv.location}
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Deliverables Viewer -->
  <section class="border-b border-border bg-surface-warm no-print">
    <div class="max-w-5xl mx-auto px-5 py-10">
      <div class="flex items-center justify-between mb-6">
        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-primary-dark">Work Samples</span>
          <h2 class="font-display text-2xl font-bold text-ink mt-1 tracking-tight">Deliverables</h2>
        </div>
        <a id="deliverable-open" href="#" target="_blank" rel="noopener noreferrer"
          class="hidden md:flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-ink/50 hover:text-primary-dark border border-border hover:border-primary-dark rounded px-3 py-1.5 transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          Open in new tab
        </a>
      </div>

      <!-- Desktop: two-panel viewer -->
      <div class="hidden md:flex gap-0 border border-border rounded-sm overflow-hidden" style="height: 680px;">
        <!-- Left: doc list -->
        <div class="w-64 shrink-0 border-r border-border overflow-y-auto bg-surface" id="doc-list">
