---
interface Props {
  title: string;
  description: string;
  date: string;
  slug: string;
  tags?: string[];
  featured?: boolean;
}

const { title, description, date, slug, tags = [], featured = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class:list={[
  "group relative",
  featured ? "border-b-2 border-border pb-10" : "border-b border-border pb-8"
]}>
  <a href=`${base}blog/${slug}` class="block">
    {tags.length > 0 && (
      <div class="flex gap-2 flex-wrap mb-3">
        {tags.map((tag) => (
          <span class="text-xs font-bold uppercase tracking-widest text-primary-dark bg-primary/20 px-2.5 py-1">
            {tag}
          </span>
        ))}
      </div>
    )}

    <h3 class:list={[
      "font-display font-bold text-ink group-hover:text-primary-dark transition-colors leading-tight",
      featured ? "text-3xl md:text-4xl" : "text-xl md:text-2xl"
    ]}>
      {title}
    </h3>

    <p class:list={[
      "mt-3 text-ink-light leading-relaxed",
      featured ? "text-lg" : "text-[0.95rem]"
    ]}>
      {description}
    </p>

    <div class="mt-4 flex items-center gap-3">
      <time class="text-xs uppercase tracking-wider text-ink-muted font-medium">{formattedDate}</time>
      <span class="text-ink-muted">&#183;</span>
      <span class="text-xs uppercase tracking-wider text-primary-dark font-semibold group-hover:underline">
        Read more
      </span>
    </div>
  </a>
</article>
