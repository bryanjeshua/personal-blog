---
interface Props {
  columns?: number;
  limit?: number;
  strip?: boolean;
}

const { columns = 3, limit = 0, strip = false } = Astro.props;

const imageFiles = import.meta.glob<{ default: ImageMetadata }>(
  '/public/images/gallery/*.{jpg,jpeg,png,webp,avif,gif}',
  { eager: true }
);

let images = Object.entries(imageFiles).map(([path, mod]) => {
  const filename = path.split('/').pop() || '';
  const name = filename.replace(/\.[^.]+$/, '').replace(/[-_]/g, ' ');
  const src = path.replace('/public', '');
  return { src, name, filename };
}).sort((a, b) => a.filename.localeCompare(b.filename));

if (limit > 0) {
  images = images.slice(0, limit);
}
---

{images.length > 0 ? (
  strip ? (
    <!-- Full-bleed horizontal strip mode -->
    <div class="w-full overflow-hidden">
      <div class="flex gap-1 animate-fade-up">
        {images.map((img) => (
          <div class="group relative flex-shrink-0 overflow-hidden aspect-[3/2] h-[220px] md:h-[300px] lg:h-[360px]" style="flex: 1 1 0;">
            <img
              src={`${import.meta.env.BASE_URL}${img.src.startsWith('/') ? img.src.slice(1) : img.src}`}
              alt={img.name}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <p class="absolute bottom-3 left-4 text-white text-sm font-medium capitalize">{img.name}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  ) : (
    <!-- Grid mode -->
    <div class:list={[
      "grid gap-4",
      columns === 2 && "md:grid-cols-2",
      columns === 3 && "md:grid-cols-3",
      columns === 4 && "md:grid-cols-2 lg:grid-cols-4",
    ]}>
      {images.map((img) => (
        <div class="group relative overflow-hidden rounded-lg bg-surface-warm border border-border aspect-[4/3]">
          <img
            src={`${import.meta.env.BASE_URL}${img.src.startsWith('/') ? img.src.slice(1) : img.src}`}
            alt={img.name}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <p class="absolute bottom-3 left-4 text-white text-sm font-medium capitalize">{img.name}</p>
          </div>
        </div>
      ))}
    </div>
  )
) : (
  <div class="border-2 border-dashed border-border rounded-lg p-12 text-center">
    <p class="text-ink-muted text-sm">No photos yet. Add images to <code class="bg-surface-warm px-2 py-0.5 rounded text-xs">public/images/gallery/</code> and they'll appear here.</p>
  </div>
)}
