---
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="group relative border-t-2 border-border pt-6 hover:border-primary transition-colors duration-300">
  <div class="text-3xl mb-3">{icon}</div>
  <h3 class="font-display text-xl font-bold text-ink group-hover:text-primary-dark transition-colors">{title}</h3>
  <p class="mt-3 text-ink-light leading-relaxed text-[0.95rem]">{description}</p>
  <div class="mt-4 w-8 h-0.5 bg-primary opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
</div>
