---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Learn, Build, Tell — Bryan Jeshua', description = 'Bryan Jeshua\'s personal site — product management, AI, and building things that matter.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href=`${base}favicon.svg` />
    <link rel="icon" href=`${base}favicon.ico` />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('theme');
        if (saved === 'light') {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>
  <body>
    <!-- Yellow accent bar (vertical on desktop, horizontal on mobile) -->
    <div class="fixed top-0 left-0 w-1 h-full bg-primary z-50 hidden md:block"></div>

    <!-- Desktop: Left sidebar nav (hidden at top, slides in on scroll) -->
    <nav id="sidebar" class="hidden md:flex fixed left-0 top-0 h-full w-16 flex-col items-center py-6 z-40 bg-header-bg border-r border-border">
      <!-- Logo -->
      <a href={base} class="group mb-8">
        <img src=`${base}favicon.svg` alt="Logo" class="w-9 h-9 group-hover:scale-110 transition-transform" />
      </a>

      <!-- Nav links (vertical) -->
      <div class="flex flex-col items-center gap-6 flex-1">
        <a href={base} class="sidebar-link group" aria-label="Home">
          <svg class="w-5 h-5 text-ink-muted group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
          <span class="sidebar-tooltip">Home</span>
        </a>
        <a href=`${base}blog` class="sidebar-link group" aria-label="Blog">
          <svg class="w-5 h-5 text-ink-muted group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
          <span class="sidebar-tooltip">Blog</span>
        </a>
        <a href=`${base}about` class="sidebar-link group" aria-label="About">
          <svg class="w-5 h-5 text-ink-muted group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
          <span class="sidebar-tooltip">About</span>
        </a>
      </div>

      <!-- Theme toggle at bottom -->
      <button
        id="theme-toggle"
        type="button"
        class="relative w-9 h-9 flex items-center justify-center rounded-full border border-border hover:border-primary transition-colors mt-auto"
        aria-label="Toggle theme"
      >
        <svg class="w-4 h-4 text-ink sun-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <circle cx="12" cy="12" r="5" />
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
        <svg class="w-4 h-4 text-ink moon-icon absolute" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>
    </nav>

    <!-- Mobile: Bottom bar (hidden at top, slides up on scroll) -->
    <nav id="mobile-nav" class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-header-bg border-t border-border">
      <div class="flex items-center justify-around py-3 px-4">
        <a href={base} class="flex flex-col items-center gap-1" aria-label="Home">
          <svg class="w-5 h-5 text-ink-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
          <span class="text-[10px] text-ink-muted uppercase tracking-wider">Home</span>
        </a>
        <a href=`${base}blog` class="flex flex-col items-center gap-1" aria-label="Blog">
          <svg class="w-5 h-5 text-ink-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
          <span class="text-[10px] text-ink-muted uppercase tracking-wider">Blog</span>
        </a>
        <a href=`${base}about` class="flex flex-col items-center gap-1" aria-label="About">
          <svg class="w-5 h-5 text-ink-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
          <span class="text-[10px] text-ink-muted uppercase tracking-wider">About</span>
        </a>
        <button id="theme-toggle-mobile" type="button" class="flex flex-col items-center gap-1" aria-label="Toggle theme">
          <svg class="w-5 h-5 text-ink-muted sun-icon-mobile" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <circle cx="12" cy="12" r="5" />
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
          </svg>
          <svg class="w-5 h-5 text-ink-muted moon-icon-mobile absolute" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
          <span class="text-[10px] text-ink-muted uppercase tracking-wider">Theme</span>
        </button>
      </div>
    </nav>

    <main class="md:ml-16">
      <slot />
    </main>

    <footer class="bg-surface-dark text-white mt-0 md:ml-16">
      <div class="max-w-6xl mx-auto px-5 py-12">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div class="flex items-center gap-2.5">
            <img src=`${base}favicon.svg` alt="Logo" class="w-7 h-7" />
            <span class="font-display text-lg font-bold">Learn, Build, Tell</span>
          </div>
          <ul class="flex gap-6 text-sm text-white/60 font-body">
            <li><a href={base} class="hover:text-primary transition-colors">Home</a></li>
            <li><a href=`${base}blog` class="hover:text-primary transition-colors">Blog</a></li>
            <li><a href=`${base}about` class="hover:text-primary transition-colors">About</a></li>
          </ul>
          <p class="text-sm text-white/40 font-body">
            &copy; {new Date().getFullYear()} Bryan Jeshua
          </p>
        </div>
      </div>
      <!-- Extra padding on mobile for bottom nav -->
      <div class="h-16 md:hidden"></div>
    </footer>

    <script is:inline>
      (function() {
        const html = document.documentElement;

        function updateIcons() {
          const isDark = html.classList.contains('dark');
          document.querySelectorAll('.sun-icon, .sun-icon-mobile').forEach(function(el) { el.style.display = isDark ? 'block' : 'none'; });
          document.querySelectorAll('.moon-icon, .moon-icon-mobile').forEach(function(el) { el.style.display = isDark ? 'none' : 'block'; });
        }

        updateIcons();

        function toggleTheme() {
          html.classList.toggle('dark');
          localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
          updateIcons();
        }

        document.getElementById('theme-toggle').addEventListener('click', toggleTheme);
        document.getElementById('theme-toggle-mobile').addEventListener('click', toggleTheme);
      })();
    </script>
  </body>
</html>
